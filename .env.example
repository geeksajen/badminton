# 把這個檔案複製成 .env.local，並填入你在 Firebase 後台拿到的金鑰
# （.env.local 不會被上傳到 GitHub，請放心填入）

VITE_FIREBASE_API_KEY=你的_apiKey
VITE_FIREBASE_AUTH_DOMAIN=你的專案.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=你的專案id
VITE_FIREBASE_STORAGE_BUCKET=你的專案.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=你的_messagingSenderId
VITE_FIREBASE_APP_ID=你的_appId
