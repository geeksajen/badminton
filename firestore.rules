rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 角色判定 ────────────────────────────────────────────────
    // 三種角色：
    //  1) 系統管理員：以 Email 白名單判定（最高權限，不可被申請 / 停權）。
    //     這份白名單必須和前端 src/config.js 的 SYSTEM_ADMIN_EMAILS 完全一致。
    //  2) 教練：users/{uid}.coach_status == 'approved'（由系統管理員核准）。
    //  3) 一般使用者：其餘。
    // 全部用 Firebase Auth + Firestore 判定，Spark 免費方案即可，不需 Cloud Functions。
    function isSystemAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'geeks.ajen@gmail.com'
        ];
    }

    // 讀取自己的 users 文件來判斷是否為已核准教練。
    // 注意：get() 對「同一路徑」在單次規則評估中會被快取，所以即使是 list 查詢，
    // 也只算 1 次讀取（uid 固定為請求者本人）。
    function isCoach() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coach_status == 'approved';
    }

    // staff = 可進教練後台（管理課程 / 報名）的人：系統管理員或已核准教練。
    function isStaff() {
      return isSystemAdmin() || isCoach();
    }

    // ── 使用者 / 角色表 ─────────────────────────────────────────
    // 每位登入者一份 users/{uid}，存放角色與教練申請狀態。
    match /users/{userId} {
      // 自己可讀自己的；系統管理員可讀 / 列出全部（審核教練申請用）。
      allow get: if (request.auth != null && request.auth.uid == userId)
        || isSystemAdmin();
      allow list: if isSystemAdmin();

      // 首次登入自動建立：只能建立「自己的」文件，且初始一律是一般使用者
      // （coach_status 必須是 'none'）—— 沒有人能自建成教練。
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.coach_status == 'none';

      // 更新：
      //  - 系統管理員：可改任何人的狀態（核准 / 拒絕 / 停權），含 reviewed_at / review_note。
      //  - 本人：只能在「申請教練」流程中切換 coach_status（none ↔ pending），
      //          且不可在「已核准(approved)」時自行變更（避免自我解除/竄改）；
      //          ★ 永遠不能把自己設成 approved ★ —— 只有系統管理員能核准。
      allow update: if isSystemAdmin()
        || (
          request.auth != null
          && request.auth.uid == userId
          && resource.data.coach_status != 'approved'
          && request.resource.data.coach_status in ['none', 'pending']
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['coach_status', 'apply_reason', 'applied_at'])
        );

      allow delete: if false;
    }

    // ── 課程主表 ────────────────────────────────────────────────
    // 任何人都能瀏覽課程（首頁不需登入即可看）。
    match /courses/{courseId} {
      allow read: if true;

      // 教練 / 系統管理員可在「教練後台」新增 / 刪除課程。新課程已報名人數必須從 0 開始。
      allow create: if isStaff()
        && request.resource.data.current_registrations == 0;
      allow delete: if isStaff();

      // 更新：
      //  - 一般登入會員：報名 / 取消時只能 +1 / -1 更動 current_registrations，其他欄位都不準動。
      //    （把這個「便宜」的條件放在 OR 前面，一般報名流程就會短路、不會多打 isCoach 的讀取。）
      //  - staff：可編輯課程任何欄位（名稱、教練、時間、學費、名額上限…）。
      allow update: if (
          request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['current_registrations'])
          && request.resource.data.current_registrations is int
          && request.resource.data.current_registrations >= 0
        ) || isStaff();
    }

    // ── 報名紀錄表 ──────────────────────────────────────────────
    // 文件 ID 固定為 {uid}_{courseId}。
    match /registrations/{regId} {
      // get：讀單一文件（含 transaction 裡確認「是否已報名」時讀不存在的文件）
      // → 先用 document ID 判斷本人（便宜、resource 為 null 時也安全），否則才看是不是 staff。
      allow get: if (request.auth != null && regId.matches(request.auth.uid + '_.*'))
        || isStaff();

      // list：學員看自己的（Dashboard，先短路）；staff 看全部（教練後台）。
      allow list: if (request.auth != null && resource.data.user_id == request.auth.uid)
        || isStaff();

      // 建立時：必須是登入者本人，文件 ID 要等於 {自己的uid}_{course_id}，
      // 且只能以「待繳費、未通知匯款」的初始狀態建立 —
      // 防止學員一開始就把自己設成 confirmed 跳過繳費確認。
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && regId == request.auth.uid + '_' + request.resource.data.course_id
        && request.resource.data.status == 'pending'
        && request.resource.data.payment_notified == false;

      // 更新時：
      //  - 學員（先短路，避免多打讀取）：只能改自己的報名，user_id / course_id 不可竄改；
      //    狀態只能改成 pending（重新報名）或 cancelled（取消），
      //    ★ 不能自行設成 confirmed ★ —— 「已確認」只有 staff 能設。
      //  - staff：可改任何報名的狀態（確認收款 / 退回），但不能改 user_id。
      allow update: if (
          request.auth != null
          && resource.data.user_id == request.auth.uid
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.course_id == resource.data.course_id
          && request.resource.data.status in ['pending', 'cancelled']
        ) || (
          isStaff()
          && request.resource.data.user_id == resource.data.user_id
        );

      // 不開放前端刪除（保留紀錄，取消是把 status 改成 cancelled）。
      allow delete: if false;
    }
  }
}
